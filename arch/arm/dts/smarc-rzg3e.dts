/dts-v1/;
#include "r9a09g047.dtsi"
#include "r9a09g047-u-boot.dtsi"
#include <dt-bindings/pinctrl/rzv2h-pinctrl.h>
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "Renesas SMARC EVK based on r9a09g047e54";
	compatible = "renesas,r9a09g047e54-smarc", "renesas,r9a09g047e54", "renesas,r9a09g047";

	aliases {
		serial0 = &scif0;
	};

	chosen {
		bootargs = "ignore_loglevel";
		stdout-path = "serial0:115200n8";
	};

	memory@48000000 {
		device_type = "memory";
		/* first 128MB is reserved for secure area. */
		reg = <0x0 0x48000000 0x1 0xF8000000>;
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		global_cma: linux,cma@58000000 {
			compatible = "shared-dma-pool";
			linux,cma-default;
			reusable;
			reg = <0x0 0x58000000 0x0 0x10000000>;
		};
	};
};

&extal_clk {
	clock-frequency = <24000000>;
};

&scif0 {
	status = "okay";
};
