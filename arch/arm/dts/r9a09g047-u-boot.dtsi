		#gpio-cells = <2>;
		gpio-ranges = <&pinctrl 0 88 8>;
	};

	P12: gpio-12 {
		gpio-controller;
		#gpio-cells = <2>;
		gpio-ranges = <&pinctrl 0 96 2>;
